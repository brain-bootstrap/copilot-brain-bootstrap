# Git ignore rules for Copilot Brain Bootstrap

# Local personal overrides
.github/copilot-instructions.local.md
.github/instructions/personal.instructions.md

# Code index (generated, not committed)
.cocoindex_code/

# Node
node_modules/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Rust
target/

# Build outputs
dist/
build/
out/

# IDE
.idea/
.vscode/settings.json
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Env files (NEVER commit secrets)
.env
.env.local
.env.*.local
